# CUFA wiki v2 — Environment Variables (placeholder)
# Copy to .env.local and fill. NEVER commit real values.
# CLAUDE.md 보안 규정 v1 준수 — 하드코딩 금지, 분기별 회전 (1/1, 4/1, 7/1, 10/1)

# --- Site ---
# Public site URL (used for canonical tags, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://cufa.wiki

# --- Luxon MCP Bridge ---
# MCP_VPS_HOST = Luxon VPS hostname (never hardcode IP)
MCP_VPS_HOST=<MCP_VPS_HOST>
MCP_BRIDGE_URL=https://<MCP_VPS_HOST>/mcp
# MCP_AUTH_TOKEN = bearer token for /api/luxon/* routes (openssl rand -hex 32)
MCP_AUTH_TOKEN=<generate-with-openssl-rand-hex-32>
MCP_BRIDGE_TOKEN=<generate-with-openssl-rand-hex-32>
# Whitelist of MCP tools reachable from the web client (prompt injection 방어)
MCP_WHITELIST=dart_latest_disclosures,dart_financial_statement,krx_stock_price_chart,ecos_interest_rate,ecos_exchange_rate,ecos_cpi,ecos_gdp,kosis_employment,ecos_bond_yield,dart_company_basic,krx_sector_heatmap,fred_us_10y,fred_vix,krx_market_summary,dart_insider_trading

# --- Supabase (Phase 4: auth + progress tracking) ---
# 진도·북마크·퀴즈 기록은 서버 없이 브라우저 localStorage(`cufa:progress:v1`)에만 저장된다.
# OAuth / DB / JWT / Session secret 세팅이 필요하지 않다. 기기 간 동기화는 하지 않는다.

# --- Upstash Rate Limit (@upstash/ratelimit, MCP/AI/Auth/DB-write routes) ---
UPSTASH_REDIS_URL=https://<name>.upstash.io
UPSTASH_REDIS_TOKEN=<token>
UPSTASH_REDIS_REST_URL=https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# --- Vercel KV (optional, used by edge cache layer) ---
VERCEL_KV_URL=<redis://...>
VERCEL_KV_REST_API_URL=https://<kv-id>.kv.vercel-storage.com
VERCEL_KV_REST_API_TOKEN=<token>
VERCEL_KV_REST_API_READ_ONLY_TOKEN=<read-only-token>

# --- Anthropic (AI 튜터 / HERMES 챗봇 서버-사이드 호출) ---
ANTHROPIC_API_KEY=<sk-ant-api03-...>
# Default model for /api/chat (override per-request 가능)
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Giscus ---
NEXT_PUBLIC_GISCUS_REPO=pollmap/CUFA-wiki
NEXT_PUBLIC_GISCUS_REPO_ID=<repo-id>
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=<category-id>

# --- HERMES AI Assistant ---
HERMES_API_URL=https://<MCP_VPS_HOST>/hermes/chat
HERMES_API_TOKEN=<token>

# --- Analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=cufa.wiki

# --- Mapbox (field-notes 맵, 무료 tier) ---
NEXT_PUBLIC_MAPBOX_TOKEN=<mapbox_public_token>
